{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tundralis.com/schemas/kda-analysis-run.schema.json",
  "title": "Tundralis KDA Analysis Run",
  "type": "object",
  "required": [
    "run_info",
    "input_summary",
    "outcome",
    "model_diagnostics",
    "drivers",
    "chart_payloads",
    "recommendations"
  ],
  "properties": {
    "run_info": {
      "type": "object",
      "required": ["analysis_type", "generated_at", "status"],
      "properties": {
        "analysis_type": {"const": "kda"},
        "generated_at": {"type": "string"},
        "status": {"type": "string", "enum": ["ok", "warning", "error"]},
        "project_id": {"type": ["string", "null"]},
        "version": {"type": ["string", "null"]},
        "warnings": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "input_summary": {
      "type": "object",
      "required": ["source_file", "rows_input", "rows_modeled", "target_column", "predictor_columns"],
      "properties": {
        "source_file": {"type": "string"},
        "rows_input": {"type": "integer"},
        "rows_modeled": {"type": "integer"},
        "rows_dropped": {"type": "integer"},
        "target_column": {"type": "string"},
        "predictor_columns": {"type": "array", "items": {"type": "string"}},
        "weight_column": {"type": ["string", "null"]},
        "segment_columns": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "outcome": {
      "type": "object",
      "required": ["name", "label", "scale", "summary"],
      "properties": {
        "name": {"type": "string"},
        "label": {"type": "string"},
        "scale": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {"type": "number"},
            "max": {"type": "number"}
          }
        },
        "summary": {
          "type": "object",
          "required": ["mean", "std_dev"],
          "properties": {
            "mean": {"type": "number"},
            "std_dev": {"type": "number"},
            "normalized_mean_0_100": {"type": "number"}
          }
        }
      },
      "additionalProperties": true
    },
    "model_diagnostics": {
      "type": "object",
      "required": ["importance_method", "impact_method", "nonlinear_benchmark_method", "r_squared", "adj_r_squared"],
      "properties": {
        "importance_method": {"type": "string"},
        "impact_method": {"type": "string"},
        "nonlinear_benchmark_method": {"type": ["string", "null"]},
        "r_squared": {"type": "number"},
        "adj_r_squared": {"type": "number"},
        "f_statistic": {"type": ["number", "null"]},
        "f_p_value": {"type": ["number", "null"]},
        "method_agreement": {"type": "string", "enum": ["high", "moderate", "low", "unknown"]},
        "nonlinear_signal": {"type": "string", "enum": ["none", "minor", "material", "unknown"]}
      },
      "additionalProperties": true
    },
    "drivers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["driver_id", "driver_label", "performance", "importance", "impact", "opportunity", "classification"],
        "properties": {
          "driver_id": {"type": "string"},
          "driver_label": {"type": "string"},
          "performance": {
            "type": "object",
            "required": ["mean", "headroom", "normalized_mean_0_100"],
            "properties": {
              "mean": {"type": "number"},
              "std_dev": {"type": ["number", "null"]},
              "headroom": {"type": "number"},
              "normalized_mean_0_100": {"type": "number"},
              "usable_n": {"type": ["integer", "null"]}
            }
          },
          "importance": {
            "type": "object",
            "required": ["share_of_explained_variance", "rank"],
            "properties": {
              "share_of_explained_variance": {"type": "number"},
              "rank": {"type": "integer"}
            }
          },
          "impact": {
            "type": "object",
            "required": ["one_point_dv_change", "rank"],
            "properties": {
              "coefficient": {"type": ["number", "null"]},
              "one_point_dv_change": {"type": "number"},
              "max_gain": {"type": ["number", "null"]},
              "rank": {"type": "integer"}
            }
          },
          "opportunity": {
            "type": "object",
            "required": ["score", "rank"],
            "properties": {
              "score": {"type": "number"},
              "rank": {"type": "integer"},
              "components": {
                "type": "object",
                "properties": {
                  "impact_component": {"type": ["number", "null"]},
                  "headroom_component": {"type": ["number", "null"]},
                  "confidence_component": {"type": ["number", "null"]}
                },
                "additionalProperties": true
              }
            }
          },
          "classification": {
            "type": "string",
            "enum": ["Core Priority", "Foundational Driver", "High-Potential Lever", "Lower Priority"]
          },
          "narrative": {
            "type": "object",
            "properties": {
              "headline": {"type": ["string", "null"]},
              "summary": {"type": ["string", "null"]}
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "chart_payloads": {
      "type": "object",
      "required": ["importance_ranking", "impact_ranking", "classic_priority_matrix", "action_matrix", "opportunity_ranking"],
      "properties": {
        "importance_ranking": {"type": "object"},
        "impact_ranking": {"type": "object"},
        "classic_priority_matrix": {"type": "object"},
        "action_matrix": {"type": "object"},
        "opportunity_ranking": {"type": "object"}
      },
      "additionalProperties": true
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "priority", "rationale", "drivers"],
        "properties": {
          "title": {"type": "string"},
          "priority": {"type": "string", "enum": ["high", "medium", "low"]},
          "rationale": {"type": "string"},
          "drivers": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
